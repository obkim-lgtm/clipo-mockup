{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "trellis hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "trellis hook user-prompt",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "trellis hook post-tool",
            "timeout": 10,
            "async": true
          }
        ],
        "matcher": "Edit|Write|MultiEdit|Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "trellis hook stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
